---
---
<section id="contact" class="contact">
  <!-- Left: text + CTA -->
  <div class="body">
    <div class="inner">
      <h2 class="section-title">
        <span class="en">Contact</span>
        <span class="separator">—</span>
        <span class="ja">お問い合わせ</span>
      </h2>
      <p class="lead">
        課題に合わせて、最適なご提案をいたします。
      </p>
      <div class="cta-row">
        <div class="badge">
          <div class="badge-ring">
            <span class="num">10</span><span class="th">th</span>
            <span class="label">ANNIVERSARY</span>
            <span class="since">Since 2015</span>
          </div>
        </div>
        <a href="/contact" class="cta-btn">映像のご相談はこちら →</a>
      </div>
    </div>
  </div>
  <!-- Right: camera image -->
  <div class="image">
    <img src="/images/contact.png" alt="" />
  </div>
</section>

<style>
  .contact {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 380px;
    border-top: 1px solid var(--color-border);
  }
  .body {
    background: #0a0a0a;
    display: flex;
    align-items: center;
    padding: 72px 64px;
  }
  .inner { width: 100%; }
  .section-title {
    display: flex;
    align-items: baseline;
    gap: 10px;
    font-weight: 400;
    margin-bottom: 16px;
  }
  .en {
    font-family: var(--font-en);
    font-size: 1.6rem;
    color: #fff;
    letter-spacing: 0.04em;
  }
  .separator {
    font-family: var(--font-en);
    font-size: 1.1rem;
    color: var(--color-text-muted);
  }
  .ja {
    font-size: 0.78rem;
    font-weight: 300;
    color: var(--color-text-muted);
    letter-spacing: 0.1em;
  }
  .lead {
    font-size: 0.85rem;
    font-weight: 300;
    color: rgba(255,255,255,0.55);
    line-height: 1.9;
    margin-bottom: 40px;
  }
  .cta-row {
    display: flex;
    align-items: center;
    gap: 32px;
  }
  .badge {
    flex-shrink: 0;
  }
  .badge-ring {
    width: 90px;
    height: 90px;
    border-radius: 50%;
    border: 1px solid var(--color-gold);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1px;
  }
  .num {
    font-family: var(--font-en);
    font-size: 1.9rem;
    font-weight: 300;
    color: var(--color-gold);
    line-height: 1;
  }
  .th {
    font-family: var(--font-en);
    font-size: 0.7rem;
    color: var(--color-gold);
    margin-top: -4px;
    align-self: flex-end;
  }
  .label {
    font-family: var(--font-en);
    font-size: 0.42rem;
    letter-spacing: 0.14em;
    color: var(--color-gold);
    margin-top: 2px;
  }
  .since {
    font-family: var(--font-en);
    font-size: 0.42rem;
    letter-spacing: 0.08em;
    color: rgba(184,150,90,0.55);
  }
  .cta-btn {
    display: inline-block;
    background: var(--color-gold);
    color: #000;
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    padding: 16px 36px;
    transition: opacity 0.2s;
    white-space: nowrap;
  }
  .cta-btn:hover { opacity: 0.85; }
  .image {
    overflow: hidden;
  }
  .image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
</style>
