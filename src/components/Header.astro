---
const navItems = [
  { label: 'Works',   href: '#works' },
  { label: 'About',   href: '#about' },
  { label: 'Service', href: '#service' },
  { label: 'Topics',  href: '#topics' },
  { label: 'Studio',  href: '#studio', external: true },
];
---
<header id="header">
  <div class="inner">
    <a href="/" class="logo">
      <span class="logo-main">WADAYA</span>
      <span class="logo-sub">VIDEO PRODUCTION</span>
    </a>
    <nav>
      <ul>
        {navItems.map(item => (
          <li>
            <a href={item.href}>
              {item.label}
              {item.external && <span class="ext">外サイト</span>}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <a href="#contact" class="contact-btn">Contact</a>
  </div>
</header>

<style>
  header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: 64px;
    background: rgba(8, 8, 8, 0.88);
    backdrop-filter: blur(10px);
  }
  .inner {
    height: 100%;
    display: flex;
    align-items: center;
    padding: 0 40px;
    gap: 40px;
  }
  .logo {
    display: flex;
    flex-direction: column;
    line-height: 1;
    flex-shrink: 0;
    gap: 3px;
  }
  .logo-main {
    font-family: var(--font-en);
    font-size: 1.25rem;
    font-weight: 400;
    letter-spacing: 0.18em;
    color: #fff;
  }
  .logo-sub {
    font-family: var(--font-en);
    font-size: 0.55rem;
    letter-spacing: 0.22em;
    color: rgba(255,255,255,0.4);
  }
  nav {
    flex: 1;
    display: flex;
    justify-content: flex-end;
  }
  nav ul {
    display: flex;
    list-style: none;
    gap: 32px;
    align-items: center;
  }
  nav a {
    font-family: var(--font-en);
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.7);
    transition: color 0.2s;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }
  nav a:hover { color: #fff; }
  .ext {
    font-size: 0.5rem;
    letter-spacing: 0.06em;
    color: rgba(255,255,255,0.3);
    font-family: var(--font-sans);
  }
  .contact-btn {
    font-family: var(--font-en);
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    border: 1px solid var(--color-gold);
    padding: 7px 20px;
    color: var(--color-gold);
    flex-shrink: 0;
    transition: all 0.2s;
  }
  .contact-btn:hover {
    background: var(--color-gold);
    color: #000;
  }
</style>
